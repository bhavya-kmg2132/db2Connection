    /// <summary>
    /// Maps the GetPolicyByNumberAsync API response to Policy entity
    /// </summary>
    private Policy? MapPolicyInfoResponseToPolicy(string responseJson)
    {
        if (string.IsNullOrWhiteSpace(responseJson))
        {
            _logger.LogWarning("Empty response received for policy lookup");
            return null;
        }

        try
        {
            var options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

            var apiResponse = JsonSerializer.Deserialize<PolicyInfoResponse>(responseJson, options);
            var policyDto = apiResponse?.Result?.FirstOrDefault();

            if (policyDto == null)
            {
                _logger.LogWarning("No policy found in response");
                return null;
            }

            // Map nested objects to Policy entity
            var policy = new Policy
            {
                //InsuredName = policyDto. ?? string.Empty,
                PolicyId = Convert.ToString(policyDto?.PolicyId),
                PolicyNo = policyDto.PolicyNumber,
                EffectiveDate = ParseDateTime(policyDto.Term?.EffectiveDate),
                ExpirationDate = ParseDateTime(policyDto.Term?.ExpirationDate),
                // Map CONTACT info
                PhoneNumber = policyDto.Contact?.Phones?.FirstOrDefault()?.PhoneNumber,
                Telephone = policyDto.Contact?.Phones?.FirstOrDefault()?.PhoneNumber,
                Email = policyDto.Contact?.Email ?? string.Empty,
                // Map address to individual fields
                Address1 = policyDto.Contact?.MailingAddress?.Address1,
                Address2 = policyDto.Contact?.MailingAddress?.Address2,
                City = policyDto.Contact?.MailingAddress?.City,
                Zip = policyDto.Contact?.MailingAddress?.ZipCode,
                // Map VEHICLES (comma-separated for single field)
                VehicleInfo = MapVehicles(policyDto.Vehicles),
                // Map DRIVERS (comma-separated for single field)
                DriverInfo = MapDrivers(policyDto.Drivers),
                // Map RATING
                TotalPremium = ParseDecimal(policyDto.Rating?.TotalPremium),
                WrittenPremium = ParseDecimal(policyDto.Rating?.TotalPremium),
                // PolicyFee doesn't exist in entity - could add as custom field if needed
            };

            _logger.LogInformation("Successfully mapped policy {PolicyNumber}", policy.PolicyNo);
            return policy;
        }
        catch (JsonException ex)
        {
            _logger.LogError(ex, "Failed to deserialize policy response");
            return null;
        }
    }

    private static DateTime? ParseDateTime(string? dateStr)
    {
        if (string.IsNullOrWhiteSpace(dateStr))
            return null;

        // Handle format: yyyyMMdd
        if (DateTime.TryParseExact(dateStr, "yyyyMMdd", null, System.Globalization.DateTimeStyles.None, out var date))
            return date;

        return null;
    }

    private static decimal? ParseDecimal(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (decimal.TryParse(value, out var result))
            return result;

        return null;
    }

    private static string MapDrivers(List<DriverInfo>? drivers)
    {
        if (drivers == null || !drivers.Any())
            return string.Empty;

        return string.Join("; ", drivers.Select(d =>
            $"{d.FirstName} {d.LastName} (License: {d.DriverLicenseNumber})"));
    }

    private static string MapVehicles(List<VehicleInfo>? vehicles)
    {
        if (vehicles == null || !vehicles.Any())
            return string.Empty;

        return string.Join("; ", vehicles.Select(v =>
            $"{v.Year} {v.Make} {v.Model} (VIN: {v.Vin})"));
    }
