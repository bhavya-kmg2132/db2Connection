import axios from 'axios';
import type { Quote, Policy, AppNotification, Endorsement, Vehicle, Driver, LineOfBusiness, TransactionType, QuoteStatus, BusinessType } from '@/core/types';
import {
  MOCK_QUOTES, MOCK_NOTIFICATIONS, MOCK_ENDORSEMENTS,
  MOCK_VEHICLES, MOCK_DRIVERS,
} from '@/core/api/mockData';
import staticPolicies from '@/core/api/policies.json';

const BASE_URL = '';

// Static policies cache - used when API fails
let staticPoliciesCache: Policy[] | null = null;

function delay(ms = 600) {
  return new Promise(res => setTimeout(res, ms));
}

// ─── Real API types (internal) ────────────────────────────────────────
interface ApiPolicyRecord {
  policyId: string;
  insuredName: string;
  phoneNumber?: string;
  mobileNumber?: string;
  policyNo: string;
  quoteId?: string;
  productName?: string;
  agentCode: string;
  accountingDate?: string;
  effectiveDate: string;
  expirationDate?: string;
  policyExpirationDate?: string;
  transactionType?: string;
  transactionCode?: string;
  telephone?: string;
  email?: string;
  contactName?: string;
  insuredContactName?: string;
  businessType?: string;
  companyCode?: string;
  heldBy?: string;
  state?: string;
  stateShortName?: string;
  address1?: string;
  address2?: string | null;
  city?: string;
  zip?: string;
  ssnFein?: string;
  licenseNumber?: string;
  relatedPolicyNumber?: string | null;
  vehicleCount?: number;
  driverCount?: number;
  writtenPremium?: number;
  totalPremium?: number;
  hiredAuto?: string;
  nonOwned?: string;
  driveOtherCar?: string;
}

const LOB_MAP: Record<string, LineOfBusiness> = {
  'Commercial Auto': 'Commercial Auto',
  'Personal Auto': 'MA Personal Auto',
  'MA Personal Auto': 'MA Personal Auto',
  'MA Commercial Auto': 'MA Commercial Auto',
};

const TX_TYPE_MAP: Record<string, TransactionType> = {
  'NEW POLICY': 'Quote',
  'RENEWAL': 'Renewal',
  'ENDORSEMENT': 'Endorsement',
  'CANCELLATION': 'Cancellation',
};

const STATUS_MAP: Record<string, QuoteStatus> = {
  NB: 'Active',
  RN: 'Active',
  EN: 'Active',
  CN: 'Declined',
};

function mapApiPolicy(p: ApiPolicyRecord): Policy {
  const addressParts = [p.address1, p.address2 ?? undefined, p.city, p.stateShortName ?? p.state, p.zip]
    .filter(Boolean)
    .join(', ');

  return {
    id: p.policyId,
    policyNumber: p.policyNo,
    quoteId: p.quoteId,
    insuredName: p.insuredName,
    lineOfBusiness: LOB_MAP[p.productName ?? ''] ?? 'Commercial Auto',
    effectiveDate: p.effectiveDate,
    expirationDate: p.expirationDate ?? p.policyExpirationDate ?? '',
    status: STATUS_MAP[p.transactionCode ?? ''] ?? 'Active',
    premium: p.totalPremium ?? p.writtenPremium ?? 0,
    agentCode: p.agentCode,
    transDate: p.accountingDate ?? p.effectiveDate,
    transactionType: TX_TYPE_MAP[(p.transactionType ?? '').toUpperCase()] ?? 'Quote',
    heldBy: p.heldBy ?? p.companyCode ?? '',
    phone: p.phoneNumber ?? p.telephone ?? p.mobileNumber,
    email: p.email,
    contactName: p.contactName ?? p.insuredContactName,
    insuredContactName: p.insuredContactName ?? p.contactName,
    licenseNumber: p.licenseNumber ?? p.ssnFein,
    address: addressParts,
    relatedPolicy: p.relatedPolicyNumber ?? undefined,
    vehicleCount: p.vehicleCount ?? 0,
    driverCount: p.driverCount ?? 0,
    hiredAuto: (p.hiredAuto ?? '').toUpperCase() === 'Y',
    nonOwnedAuto: (p.nonOwned ?? '').toUpperCase() === 'Y',
    driveOtherCar: (p.driveOtherCar ?? '').toUpperCase() === 'Y',
    state: p.state ?? p.stateShortName,
    businessType: p.businessType as BusinessType | undefined,
  };
}

// Initialize static policies cache from policies.json
function getStaticPoliciesCache(): Policy[] {
  if (staticPoliciesCache === null) {
    staticPoliciesCache = staticPolicies.map((p: any) => mapApiPolicy(p));
  }
  return staticPoliciesCache;
}

// Quotes
export const quoteService = {
  async list(): Promise<Quote[]> {
    await delay();
    return [...MOCK_QUOTES];
  },
  async get(id: string): Promise<Quote | null> {
    await delay(300);
    return MOCK_QUOTES.find(q => q.id === id || q.quoteId === id) ?? null;
  },
  async create(data: Partial<Quote>): Promise<Quote> {
    await delay(800);
    const now = new Date().toISOString().split('T')[0];
    const newQuote: Quote = {
      id: `q${Date.now()}`,
      quoteId: `MCAQ${Math.floor(Math.random() * 900000 + 100000)}`,
      status: 'Draft',
      lineOfBusiness: data.lineOfBusiness ?? 'MA Commercial Auto',
      transactionType: 'Quote',
      transDate: now,
      effectiveDate: data.effectiveDate ?? now,
      endDate: data.endDate ?? now,
      agentCode: '00130',
      heldBy: 'Co',
      insuredName: data.insuredName ?? '',
      vehicles: [],
      drivers: [],
      formCompleteness: 0,
      estimatedPremium: 0,
      ...data,
    };
    MOCK_QUOTES.push(newQuote);
    return newQuote;
  },
  async update(id: string, data: Partial<Quote>): Promise<Quote> {
    await delay(400);
    const idx = MOCK_QUOTES.findIndex(q => q.id === id);
    if (idx === -1) throw new Error('Quote not found');
    MOCK_QUOTES[idx] = { ...MOCK_QUOTES[idx], ...data };
    return MOCK_QUOTES[idx];
  },
  async generateQuote(id: string): Promise<Quote> {
    await delay(1200);
    const idx = MOCK_QUOTES.findIndex(q => q.id === id);
    if (idx === -1) throw new Error('Quote not found');
    const premium = MOCK_QUOTES[idx].vehicles.reduce((sum, v) => sum + (v.coverage ? 1540 : 0), 1200);
    MOCK_QUOTES[idx] = {
      ...MOCK_QUOTES[idx],
      status: 'Quoted',
      estimatedPremium: premium,
      formCompleteness: 100,
      premiumBreakdown: {
        totalPremium: premium,
        vehicles: MOCK_QUOTES[idx].vehicles.map(v => ({
          vinNumber: v.vinNumber,
          make: `${v.year} ${v.make} ${v.model}`,
          year: v.year,
          modal: v.type,
          premium: Math.round(premium / Math.max(MOCK_QUOTES[idx].vehicles.length, 1)),
        })),
      },
    };
    return MOCK_QUOTES[idx];
  },
};

// Policies
export const policyService = {
  async list(search = ''): Promise<Policy[]> {
    try {

      //  const res = await fetch(`${BASE_URL}/api/Policies`, {
      // method: 'POST',
      // headers: { 'Content-Type': 'application/json', accept: '*/*' },
      // body: JSON.stringify({ search }),
      const res = await fetch(`${BASE_URL}/api/Policies/quotes`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', accept: '*/*' },
        body: JSON.stringify({
         
          searchkey: search || "",
         
        }),
      });
      if (!res.ok) {
        throw new Error(`API returned ${res.status}`);
      }
      const data: ApiPolicyRecord[] = await res.json();
      return data.map(mapApiPolicy);
    } catch (error) {
      console.warn('Failed to fetch policies from API, using static data:', error);
      const normalizedSearch = search.trim().toLowerCase();
      const cache = getStaticPoliciesCache();
      if (!normalizedSearch) return cache;
      return cache.filter(p =>
        p.insuredName.toLowerCase().includes(normalizedSearch) ||
        p.policyNumber.toLowerCase().includes(normalizedSearch)
      );
    }
  },
  async get(id: string): Promise<Policy | null> {
    try {
      const { data } = await axios.get<ApiPolicyRecord | ApiPolicyRecord[]>(`${BASE_URL}/api/Policies/${id}`);
      const record = Array.isArray(data) ? data[0] : data;
      if (record) return mapApiPolicy(record);
    } catch (error) {
      console.warn('Failed to fetch policy from API:', error);
    }
    const cache = getStaticPoliciesCache();
    return cache.find(p => p.id === id || p.policyNumber === id) ?? null;
  },
  async updatePhone(id: string, phoneNumber: string): Promise<void> {
    try {
      await axios.put(`${BASE_URL}/api/Policies/${id}/phone`, { phoneNumber });
    } catch (error) {
      console.warn('Failed to update phone via API, updating static cache:', error);
      const cache = getStaticPoliciesCache();
      const policy = cache.find(p => p.id === id || p.policyNumber === id);
      if (policy) {
        policy.phone = phoneNumber;
      } else {
        throw new Error(`Policy not found: ${id}`);
      }
    }
  },
};

// Notifications
export const notificationService = {
  async list(): Promise<AppNotification[]> {
    await delay(200);
    return [...MOCK_NOTIFICATIONS];
  },
  async markRead(id: string): Promise<void> {
    await delay(100);
    const n = MOCK_NOTIFICATIONS.find(n => n.id === id);
    if (n) n.read = true;
  },
  async markAllRead(): Promise<void> {
    await delay(200);
    MOCK_NOTIFICATIONS.forEach(n => (n.read = true));
  },
};

