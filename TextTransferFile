// Vehicle validation (RMV mock)
export const vehicleService = {
  async validateVIN(vin: string): Promise<Vehicle | null> {
    await delay(1000);
    const existing = MOCK_VEHICLES.find(v => v.vinNumber === vin);
    if (existing) return existing;
    if (vin.length >= 10) {
      return {
        id: `v${Date.now()}`,
        vinNumber: vin,
        year: '2022',
        make: '2022 Ford Transit 250',
        model: 'Transit 250',
        type: 'Truck',
        rmvStatus: Math.random() > 0.3 ? 'Accepted' : 'Rejected',
      };
    }
    return null;
  },
};

// Driver validation (RMV mock)
export const driverService = {
  async validateLicense(licenseNumber: string, state: string): Promise<Driver | null> {
    await delay(1000);
    const existing = MOCK_DRIVERS.find(d => d.licenseNumber === licenseNumber);
    if (existing) return existing;
    if (licenseNumber.length >= 6) {
      return {
        id: `d${Date.now()}`,
        licenseNumber,
        state,
        firstName: 'John',
        lastName: 'Smith',
        dateOfBirth: '01/15/1985',
        age: 35,
        gender: 'Male',
        licenseStatus: 'Active',
        rmvStatus: Math.random() > 0.3 ? 'Accepted' : 'Rejected',
        namedInsured: 'None',
      };
    }
    return null;
  },
};
